---
import '../styles/global.css';
const {
  title = 'Garden',
  description = '게임과 책에서 시작된 에세이를 가꾸는 ELAI의 정원',
} = Astro.props;
const full = title === 'Garden' ? 'ELAI · Garden' : `${title} · ELAI`;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" />
    <title>{full}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="shell nav">
        <a class="brand" href="/">ELAI’s <em>Garden</em></a>
        <div class="nav-links">
          <a href="/essays">Essays</a>
          <a href="/library">Library</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="shell footer-row">
        <span>© {new Date().getFullYear()} ELAI.</span>
        <span>AI-assisted maintenance · <a href="/rss.xml">RSS</a></span>
      </div>
    </footer>
  </body>
</html>
